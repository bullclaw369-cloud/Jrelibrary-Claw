<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JRE Library — Every Book, Movie & Guest from the Joe Rogan Experience</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background-color: #111;
  color: #eee;
  font-family: 'Inter', sans-serif;
  line-height: 1.5;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

a { color: #ff4d4d; text-decoration: none; }
a:hover { color: #ff7a7a; }

/* NAVBAR */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1rem 2rem;
  background-color: #0a0a0a;
  border-bottom: 1px solid #222;
  position: sticky;
  top: 0;
  z-index: 100;
}
nav .logo {
  font-weight: 700;
  font-size: 1.3rem;
  color: #ff4d4d;
}
nav ul {
  display: flex;
  gap: 1.5rem;
  list-style: none;
}
nav ul a {
  color: #eee;
  font-weight: 500;
  font-size: 0.95rem;
}
nav ul a:hover { color: #ff4d4d; }
.search-icon {
  cursor: pointer;
  color: #ff4d4d;
  font-size: 1.2rem;
}

/* HERO */
.hero {
  text-align: center;
  padding: 3rem 1rem 2rem;
  background: linear-gradient(180deg, #1a0a0a 0%, #111 100%);
}
.hero h1 {
  color: #fff;
  font-size: 2.2rem;
  margin-bottom: 0.5rem;
  font-weight: 700;
}
.hero .subhead {
  color: #bbb;
  font-size: 1.1rem;
  margin-bottom: 1.5rem;
}
.search-bar {
  display: flex;
  justify-content: center;
  gap: 0.5rem;
  max-width: 600px;
  margin: 0 auto;
}
.search-bar input {
  padding: 0.75rem 1rem;
  width: 100%;
  font-size: 1rem;
  border: 1px solid #444;
  border-radius: 4px;
  background-color: #1e1e1e;
  color: #eee;
  outline: none;
}
.search-bar input:focus {
  border-color: #ff4d4d;
}
.search-submit {
  padding: 0.75rem 1.5rem;
  background-color: #ff4d4d;
  color: #fff;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  font-size: 1rem;
  white-space: nowrap;
}
.search-submit:hover { background-color: #e03c3c; }

/* CATEGORY CARDS ROW */
.section-title {
  padding: 1.5rem 2rem 0.5rem;
  font-size: 1.1rem;
  font-weight: 600;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.cards-row {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  justify-content: center;
  padding: 1rem 2rem;
}
.card {
  background-color: #1e1e1e;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  padding: 1.2rem 1rem;
  flex: 1 1 150px;
  max-width: 180px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.2s, transform 0.2s;
}
.card:hover {
  border-color: #ff4d4d;
  transform: translateY(-2px);
}
.card .icon { font-size: 2rem; margin-bottom: 0.5rem; }
.card h3 {
  font-size: 0.95rem;
  font-weight: 600;
  color: #eee;
}

/* RECENT MENTIONS GRID */
.mentions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  padding: 1rem 2rem 2rem;
}
.mention-card {
  background-color: #1a1a1a;
  border: 1px solid #2a2a2a;
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.2s;
  cursor: pointer;
}
.mention-card:hover {
  border-color: #ff4d4d;
  transform: translateY(-2px);
}
.mention-card img {
  width: 100%;
  height: 120px;
  object-fit: cover;
  display: block;
}
.mention-card .info {
  padding: 0.75rem;
}
.mention-card .info h3 {
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 0.4rem;
  color: #eee;
}
.badge {
  display: inline-block;
  background-color: #ff4d4d;
  color: #fff;
  padding: 0.2rem 0.5rem;
  font-size: 0.75rem;
  border-radius: 4px;
  font-weight: 600;
}

/* FOOTER */
footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.2rem 2rem;
  background-color: #0a0a0a;
  border-top: 1px solid #222;
  margin-top: auto;
  color: #bbb;
  font-size: 0.9rem;
}
footer .links {
  display: flex;
  gap: 1.5rem;
}
footer .links a {
  color: #bbb;
}
footer .links a:hover { color: #eee; }

/* RESPONSIVE */
@media (max-width: 768px) {
  nav ul { display: none; }
  .hero h1 { font-size: 1.6rem; }
  .cards-row { gap: 0.75rem; }
  .card { max-width: 45%; }
  .mentions-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .mentions-grid { grid-template-columns: 1fr; }
  .card { max-width: 100%; }
  footer { flex-direction: column; gap: 0.75rem; text-align: center; }
}
</style>
</head>
<body>

  <!-- NAVBAR -->
  <nav>
    <div class="logo">JRE Library</div>
    <ul>
      <li><a href="#">Books</a></li>
      <li><a href="#">Movies</a></li>
      <li><a href="#">Music</a></li>
      <li><a href="#">Guests</a></li>
      <li><a href="#">Episodes</a></li>
    </ul>
    <div class="search-icon">🔍</div>
  </nav>

  <!-- HERO / SEARCH BAR -->
  <section class="hero">
    <h1>Every Book, Movie &amp; Guest from the JRE</h1>
    <div class="subhead">Search 2,600+ episodes</div>
    <div class="search-bar">
      <input type="text" placeholder="Search books, guests, episodes...">
      <button class="search-submit">Search</button>
    </div>
  </section>

  <!-- CATEGORY CARDS ROW -->
  <div class="section-title">Browse by Category</div>
  <section class="cards-row">
    <div class="card">
      <div class="icon">📚</div>
      <h3>Books</h3>
    </div>
    <div class="card">
      <div class="icon">🎬</div>
      <h3>Movies</h3>
    </div>
    <div class="card">
      <div class="icon">🎵</div>
      <h3>Music</h3>
    </div>
    <div class="card">
      <div class="icon">🎙️</div>
      <h3>Guests</h3>
    </div>
    <div class="card">
      <div class="icon">🔗</div>
      <h3>Products</h3>
    </div>
  </section>

  <!-- RECENT MENTIONS GRID -->
  <div class="section-title">Recent Mentions</div>
  <section class="mentions-grid">
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Books" alt="Fear and Loathing">
      <div class="info">
        <h3>Fear and Loathing in Las Vegas</h3>
        <span class="badge">Book</span>
      </div>
    </div>
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Guest" alt="Elon Musk">
      <div class="info">
        <h3>Elon Musk</h3>
        <span class="badge">Guest #1169</span>
      </div>
    </div>
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Movies" alt="Apocalypse Now">
      <div class="info">
        <h3>Apocalypse Now</h3>
        <span class="badge">Movie</span>
      </div>
    </div>
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Guest" alt="Neil deGrasse Tyson">
      <div class="info">
        <h3>Neil deGrasse Tyson</h3>
        <span class="badge">Guest #817</span>
      </div>
    </div>
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Music" alt="Duff McKagan">
      <div class="info">
        <h3>Duff McKagan</h3>
        <span class="badge">Guest #712</span>
      </div>
    </div>
    <div class="mention-card">
      <img src="https://via.placeholder.com/400x120/1a1a1a/ff4d4d?text=Books" alt="Adventures of Huckleberry Finn">
      <div class="info">
        <h3>Adventures of Huckleberry Finn</h3>
        <span class="badge">Book</span>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="left">JRE Library © 2026</div>
    <div class="links">
      <a href="#">About</a>
      <a href="#">Submit</a>
      <a href="#">Privacy</a>
    </div>
  </footer>

</body>
</html>
